{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schema/master/tauri-config-v2.json",
  "productName": "RetroAmp",
  "identifier": "com.retroamp.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RetroAmp",
        "width": 275,
        "height": 500,
        "resizable": true,
        "decorations": false,
        "minWidth": 275,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
