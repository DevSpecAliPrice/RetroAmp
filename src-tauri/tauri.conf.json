{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schema/master/tauri-config-v2.json",
  "productName": "RetroAmp",
  "identifier": "com.retroamp.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../skins/*.wsz": "skins/"
    },
    "publisher": "RetroAmp",
    "category": "Music",
    "shortDescription": "Cross-platform desktop audio player inspired by Winamp 2.x",
    "longDescription": "RetroAmp is a cross-platform desktop audio player inspired by Winamp 2.x. Plays local files, internet radio, and YouTube Music; supports classic Winamp skins, Milkdrop visualisations, and a 10-band EQ.",
    "homepage": "https://github.com/DevSpecAliPrice/RetroAmp",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/DevSpecAliPrice/RetroAmp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyRUE0RkIyODk0N0ZGMjcKUldRbi8wZUpzay9xVWpFZmxKRzRVVkN3N3djMFVwTUw5ekFtRWVOZ20zSTkrTlhqR0Q3N01TZlcK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
